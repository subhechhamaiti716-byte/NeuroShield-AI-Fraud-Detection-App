# NeuroShield Environment Variables Example

# Application Settings
PROJECT_NAME="NeuroShield API"
SECRET_KEY="replace-this-with-a-very-long-secure-random-string"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration
DATABASE_URL="sqlite:///./neuroshield.db" # or "postgresql://user:password@localhost:5432/neuroshield_db"
REDIS_URL="redis://localhost:6379/0"

# CORS
FRONTEND_URL="http://localhost:8081,http://localhost:3000"

# Razorpay Config (Get these from razorpay.com)
RAZORPAY_KEY_ID="rzp_test_mockkeyid123"
RAZORPAY_KEY_SECRET="mocksecretkey456"

# Plaid Config (Get these from plaid.com)
PLAID_CLIENT_ID="your_plaid_client_id"
PLAID_SECRET="your_plaid_secret"
PLAID_ENV="sandbox" # Options: sandbox, development, production

# Background Jobs Settings
SYNC_INTERVAL_MINUTES=5
RETRAIN_INTERVAL_HOURS=24

# Frontend WebSocket Fallback (Optional)
# EXPO_PUBLIC_API_URL="https://your-backend-url.onrender.com"
# EXPO_PUBLIC_WS_URL="wss://your-backend-url.onrender.com/ws/alerts"
