# NeuroShield Environment Variables Example

# Application Settings
PROJECT_NAME="NeuroShield API"
SECRET_KEY="replace-this-with-a-very-long-secure-random-string"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration
DATABASE_URL="sqlite:///./neuroshield.db" # or "postgresql://user:password@localhost:5432/neuroshield_db"
REDIS_URL="redis://localhost:6379/0"

# CORS
FRONTEND_URL="http://localhost:8081,http://localhost:3000"

# Razorpay Config (Mock for local)
RAZORPAY_KEY_ID="rzp_test_mockkeyid123"
RAZORPAY_KEY_SECRET="mocksecretkey456"

# Background Jobs Settings
SYNC_INTERVAL_MINUTES=5
RETRAIN_INTERVAL_HOURS=24
